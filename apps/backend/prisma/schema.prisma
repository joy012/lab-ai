generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  email             String    @unique
  passwordHash      String
  name              String?
  phone             String?
  role              String    @default("PATIENT") // PATIENT | DOCTOR | ADMIN
  emailVerified     Boolean   @default(false)
  verificationToken String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  refreshToken      String?
  avatarUrl         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  labReports        LabReport[]
  healthProfile     HealthProfile?
}

model LabReport {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String    @db.ObjectId
  doctorId        String?   @db.ObjectId
  title           String?
  reportType      String    @default("LAB_REPORT") // "LAB_REPORT" | "ECG" | "IMAGING"
  // Per-report patient context (for doctors uploading different patient reports)
  patientAge      Int?
  patientGender   String?   // "Male" | "Female" | "Other"
  clinicalHistory String?   // Chief complaint, symptoms, relevant history
  imageUrl        String
  imageUrls       String[]
  rawText         String?
  values          Json?
  summary         String?
  summaryBn       String?
  diagnosis       String[]
  diagnosisBn     String[]
  diagnosisStatus String?   // "all_clear" | "mild" | "moderate" | "serious"
  riskScore       Int?
  recommendations Json?
  // ECG-specific fields
  ecgFindings     Json?     // ECGFinding[] — heart rate, rhythm, intervals, axis
  // Imaging-specific fields
  imagingModality String?   // "MRI" | "CT" | "X-RAY" | "USG"
  imagingFindings Json?     // ImagingFinding[] — location, description, significance
  impression      String?   // Overall radiologist impression
  impressionBn    String?   // Bengali impression
  status          String    @default("PENDING") // PENDING | PROCESSING | COMPLETED | FAILED
  errorMessage    String?
  labName         String?
  reportDate      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])
}

model MedicalKnowledge {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  category  String   // e.g., "test_info", "condition", "diet", "medication"
  title     String
  content   String
  tags      String[]
  source    String?  // e.g., "WHO", "BMDC", "user_feedback"
  embedding Float[]  // Vector embedding for similarity search
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiPersona {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  name        String
  style       String   // "simple" | "detailed" | "diet-focused" | "concern-focused"
  preferences Json     // { focusAreas, tone, language }
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HealthProfile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @unique @db.ObjectId
  age         Int?
  gender      String?
  weight      Float?
  height      Float?
  bloodGroup  String?
  conditions  String[]
  medications String[]
  allergies   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}
