PORT: 3001
CORS_ORIGIN: '*'

# MongoDB - Local for dev (install: brew install mongodb-community, then: brew services start mongodb-community)
# For production: use MongoDB Atlas free M0 tier at https://cloud.mongodb.com
DATABASE_URL: mongodb://localhost:27017/labai

# JWT - Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Two secrets: access (short-lived) and refresh (long-lived) for security isolation
JWT_SECRET: YOUR_JWT_SECRET_HERE
JWT_REFRESH_SECRET: YOUR_JWT_REFRESH_SECRET_HERE
JWT_EXPIRY: 15m
JWT_REFRESH_EXPIRY: 30d

# AI Models - Get Gemini key at: https://aistudio.google.com/apikey (free: 15 RPM, 1M tokens/day)
GEMINI_API_KEY: YOUR_GEMINI_API_KEY
# Groq - Get key at: https://console.groq.com (free: 30 RPM, fast Llama models)
GROQ_API_KEY: YOUR_GROQ_API_KEY

# File Storage - Cloudinary (free: 25GB storage, 25GB bandwidth)
# Sign up at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME: YOUR_CLOUD_NAME
CLOUDINARY_API_KEY: YOUR_API_KEY
CLOUDINARY_API_SECRET: YOUR_API_SECRET
UPLOAD_DIR: ./uploads
MAX_FILE_SIZE: 10485760

# Email - Gmail SMTP (enable 2FA → App Passwords at https://myaccount.google.com/apppasswords)
SMTP_HOST: smtp.gmail.com
SMTP_PORT: 587
SMTP_USER: your-email@gmail.com
SMTP_PASS: your-app-password
MAIL_FROM: 'LabAI <your-email@gmail.com>'

# App URLs
APP_URL: http://localhost:3001
CLIENT_URL: http://localhost:8081
WEB_URL: http://localhost:3000
